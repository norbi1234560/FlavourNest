<Window x:Class="FlavourNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FlavourNest - Admin Dashboard"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Background="#34495E" Height="80" Padding="20">
                    <TextBlock Text="FlavourNest Admin"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="0,20,0,0">
                    <Button Content="📊 Dashboard" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="Dashboard_Click"/>
                    <Button Content="📝 Recipe Management" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="RecipeManagement_Click"/>
                    <Button Content="👥 User Management" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="Users_Click"/>
                    <Button Content="🗂️ Categories" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="Categories_Click"/>
                    <Button Content="📈 Analytics" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="Analytics_Click"/>
                    <Button Content="⚙️ Settings" Style="{StaticResource SidebarButtonStyle}" Height="50" Click="Settings_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl x:Name="MainTabs" Grid.Column="1"
                    BorderThickness="0"
                    Background="Transparent">

            <!-- Hide Tab Headers -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- TAB 0: Dashboard -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="📊 Dashboard" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock Text="Welcome to FlavourNest Admin Dashboard!" FontSize="16" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 1: Recipe Management -->
            <TabItem>
                <StackPanel Margin="20">
                    <TextBlock Text="📝 Recipe Management" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Button Content="➕ Add New Recipe" Background="#4CAF50" Foreground="White" Padding="12,6" Width="180" BorderThickness="0"/>
                    <DataGrid Name="dataGrid0" HorizontalAlignment="Left" Height="232" Margin="30,26,0,0" VerticalAlignment="Top" Width="465" AutoGenerateColumns="False" d:ItemsSource="{d:SampleData ItemCount=5}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" />
                            <DataGridTextColumn Header="title" />
                            <DataGridTextColumn Header="description" />
                            <DataGridTextColumn Header="author_id" />
                            <DataGridTextColumn Header="servings" />
                            <DataGridTextColumn Header="prep_time_minutes" />
                            <DataGridTextColumn Header="created_at" />
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>
            </TabItem>

            <!-- TAB 2: User Management -->
            <TabItem>
                <StackPanel Margin="20">
                    <TextBlock Text="👥 User Management" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Button Content="➕ Add User" Background="#3498DB" Foreground="White" Padding="12,6" Width="150" BorderThickness="0"/>
                    <DataGrid Name="dataGrid1" HorizontalAlignment="Left" Height="232" Margin="30,26,0,0" VerticalAlignment="Top" Width="465" AutoGenerateColumns="False" d:ItemsSource="{d:SampleData ItemCount=5}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" />
                            <DataGridTextColumn Header="user" />
                            <DataGridTextColumn Header="email" />
                            <DataGridTextColumn Header="password" />
                            <DataGridTextColumn Header="display_name" />
                            <DataGridTextColumn Header="created_at  " />



                        </DataGrid.Columns>

                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- TAB 3: Categories -->
            <TabItem>
                <StackPanel Margin="20">
                    <TextBlock Text="🗂️ Categories" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Button Content="➕ Add Category" Background="#9B59B6" Foreground="White" Padding="12,6" Width="180" BorderThickness="0"/>
                    <DataGrid Name="dataGrid2" HorizontalAlignment="Left" Height="232" Margin="30,26,0,0" VerticalAlignment="Top" Width="465" AutoGenerateColumns="False" d:ItemsSource="{d:SampleData ItemCount=5}">



                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- TAB 4: Analytics -->   
            <TabItem>
                <StackPanel Margin="20">
                    <TextBlock Text="📈 Analytics" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Analytics charts and stats will appear here." FontSize="16"/>
                    <DataGrid Name="dataGrid3" HorizontalAlignment="Left" Height="232" Margin="30,26,0,0" VerticalAlignment="Top" Width="465" AutoGenerateColumns="False" d:ItemsSource="{d:SampleData ItemCount=5}">


                    </DataGrid>
                </StackPanel>
            </TabItem>

            <!-- TAB 5: Settings -->
            <TabItem>
                <StackPanel Margin="20">
                    <TextBlock Text="⚙️ Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                    <Button Content="Save Settings" Background="#3498DB" Foreground="White" Padding="12,6" Width="160" BorderThickness="0"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
