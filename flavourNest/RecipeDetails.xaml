<Window x:Class="flavourNest.RecipeDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recept részletei"
        Height="700"
        Width="900"
        Background="#1f1f1f"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Border Padding="20"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b">

            <StackPanel>

                <TextBlock Name="titleText"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FFC107"
                           Margin="0,0,0,10"/>

                <TextBlock Name="authorText"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <TextBlock Name="timeText"
                           Foreground="White"
                           Margin="0,0,0,20"/>


                <TabControl>

                    <TabItem Header="Hozzávalók">
                        <DataGrid Name="ingredientsGrid"/>
                    </TabItem>

                    <TabItem Header="Lépések">
                        <DataGrid Name="stepsGrid"/>
                    </TabItem>

                    <TabItem Header="Tagek">
                        <DataGrid Name="tagsGrid"/>
                    </TabItem>

                    <TabItem Header="Értékelések">
                        <DataGrid Name="ratingsGrid"/>
                    </TabItem>

                    <TabItem Header="Kommentek">
                        <DataGrid Name="commentsGrid"/>
                    </TabItem>

                </TabControl>

                <Button Content="Bezárás"
                        Width="120"
                        Height="40"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Right"
                        Background="#FFC107"
                        Foreground="Black"
                        FontWeight="Bold"
                        Click="Close_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>