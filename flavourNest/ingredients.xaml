<Window x:Class="flavourNest.ingredients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alapanyag kezelése"
        Height="600"
        Width="600"
        MinWidth="500"
        MinHeight="400"
        Background="#1f1f1f"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Border Padding="20"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid Width="500">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Text="Alapanyag kezelése"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,15"/>

                <!-- Input + Buttons -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15"
                            Grid.Row="1">

                    <TextBox Name="ingredientTextBox"
                             Width="250"
                             Height="40"
                             FontSize="16"
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"/>

                    <Button Content="Mentés"
                            Width="90"
                            Height="40"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"
                            Margin="0,0,10,0"
                            Click="SaveButton_Click"/>

                    <Button Content="Törlés"
                            Width="90"
                            Height="40"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#dc3545"
                            Foreground="White"
                            Click="DeleteButton_Click"/>

                </StackPanel>

                <!-- Ingredient List -->
                <GroupBox Header="Minden alapanyag"
                          FontSize="16"
                          Foreground="White"
                          Grid.Row="2"
                          Margin="0,0,0,15">

                    <ListBox Name="ingredientsListBox"
                             FontSize="16"
                             Background="#1f1f1f"
                             Foreground="White"
                             SelectionChanged="ingredientsListBox_SelectionChanged"/>

                </GroupBox>

                <!-- Close -->
                <Button Content="Bezárás"
                        Width="120"
                        Height="40"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#444"
                        Foreground="White"
                        HorizontalAlignment="Right"
                        Grid.Row="3"
                        Click="CloseButton_Click"/>

            </Grid>

        </Border>

    </Grid>

</Window>