<Window x:Class="flavourNest.users"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Felhasználók"
        Height="650"
        Width="1000"
        Background="#1f1f1f"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Width="800"
                Padding="30"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20">
                    <Run Text="Felhasználók " Foreground="#FFC107"/>
                    <Run Text="listája" Foreground="White"/>
                </TextBlock>

                <DataGrid Name="adatbazis"
                          Height="250"
                          Margin="0 0 0 20"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MouseDoubleClick="adatbazis_MouseDoubleClick"
                          RowBackground="#2b2b2b"
                          AlternatingRowBackground="#343434"
                          Foreground="White"
                          GridLinesVisibility="None"
                          FontSize="14">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFC107"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                        <DataGridTemplateColumn Header="Avatar" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImageSource}" Height="40" Width="40" Stretch="UniformToFill"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Username" Binding="{Binding username}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="*"/>
                        <DataGridTextColumn Header="Password" Binding="{Binding password}" Width="*"/>
                        <DataGridTextColumn Header="Created At" Binding="{Binding created_at}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Text="Felhasználó szerkesztése"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0 0 0 10"/>

                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">

                    <StackPanel Margin="0 0 15 0">
                        <TextBlock Text="Username" Foreground="White"/>
                        <TextBox Name="usernameBox" Width="200"/>
                    </StackPanel>

                    <StackPanel Margin="0 0 15 0">
                        <TextBlock Text="Email" Foreground="White"/>
                        <TextBox Name="emailBox" Width="250"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Password" Foreground="White"/>
                        <TextBox Name="passwordBox" Width="200"/>
                    </StackPanel>

                </StackPanel>

                <UniformGrid Columns="3">

                    <Button Content="Mentés"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"
                            Click="SaveButton_Click"/>

                    <Button Name="deleteButton"
                            Content="Felhasználó törlése"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#d9534f"
                            Foreground="White"
                            Click="deleteButton_Click"/>

                    <Button Name="buttonBezaras"
                            Content="Bezárás"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#444"
                            Foreground="White"
                            Click="buttonBezaras_Click"/>

                </UniformGrid>

            </StackPanel>

        </Border>

    </Grid>

</Window>