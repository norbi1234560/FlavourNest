<Window x:Class="flavourNest.comments"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kommentek moderálása"
        Height="550"
        Width="900"
        Background="#1f1f1f"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Border Padding="20"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Kommentek moderálása"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,15"/>

                <!-- DataGrid -->
                <DataGrid Name="commentsGrid"
                          AutoGenerateColumns="False"
                          Height="300"
                          Margin="0,0,0,15"
                          IsReadOnly="True"
                          MouseDoubleClick="commentsGrid_MouseDoubleClick"
                          Background="#2b2b2b"
                          Foreground="White"
                          RowBackground="#2b2b2b"
                          AlternatingRowBackground="#333333">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFC107"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                        <DataGridTextColumn Header="Recept" Binding="{Binding recipe_title}" Width="*"/>
                        <DataGridTextColumn Header="Felhasználó" Binding="{Binding username}" Width="150"/>
                        <DataGridTextColumn Header="Komment" Binding="{Binding content}" Width="250"/>
                        <DataGridTextColumn Header="Létrehozva" Binding="{Binding created_at}" Width="150"/>

                        <DataGridTemplateColumn Header="Törlés" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Törlés"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            FontWeight="Bold"
                                            Click="DeleteButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- Edit section -->
                <TextBlock Text="Komment szerkesztése"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <TextBox Name="commentEditBox"
                         Height="70"
                         TextWrapping="Wrap"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Mentés"
                            Width="120"
                            Height="35"
                            Margin="0,0,10,0"
                            Background="#FFC107"
                            Foreground="Black"
                            FontWeight="Bold"
                            Click="SaveButton_Click"/>

                    <Button Content="Mégse"
                            Width="120"
                            Height="35"
                            Background="#444"
                            Foreground="White"
                            Click="CancelButton_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</Window>