<Window x:Class="flavourNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlavourNest Admin"
        Height="500" Width="900"
        Background="#1f1f1f"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Centered Card -->
        <Border Width="600"
                Padding="30"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- Title -->
                <TextBlock FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20">

                    <Run Text="Flavour" Foreground="#FFC107"/>
                    <Run Text="Nest" Foreground="White"/>

                </TextBlock>

                <!-- Description -->
                <TextBlock Text="Üdvözöljük a FlavourNest admin oldalán!"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextAlignment="Center"
                           Margin="0 0 0 10"/>

                <TextBlock Text="Itt kezelheti a felhasználókat, moderálhatja a kommenteket és kezelheti az alapanyagokat."
                           FontSize="16"
                           Foreground="#cccccc"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0 0 0 25"/>

                <!-- Buttons -->
                <UniformGrid Columns="2" Rows="2" Margin="0 0 0 20">

                    <Button Content="Felhasználók"
                            Click="Users_Click"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"/>

                    <Button Content="Kommentek"
                            Click="Comments_Click"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"/>

                    <Button Content="Alapanyagok"
                            Click="Ingredients_Click"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"/>

                    <Button Content="Receptek"
                            Click="Recipes_Click"
                            Margin="8"
                            Padding="12"
                            FontWeight="Bold"
                            Background="#FFC107"
                            Foreground="Black"/>

                </UniformGrid>

                <!-- Exit -->
                <Button Content="Kilépés"
                        Padding="12"
                        FontWeight="Bold"
                        Background="#444"
                        Foreground="White"
                        Click="Quit_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>