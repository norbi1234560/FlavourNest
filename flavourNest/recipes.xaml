<Window x:Class="flavourNest.recipes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receptek"
        Height="900"
        Width="1200"
        Background="#1f1f1f"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Border Padding="20"
                CornerRadius="12"
                BorderThickness="2"
                BorderBrush="#FFC107"
                Background="#2b2b2b">

            <StackPanel>

                <!-- Title -->

                <TextBlock Text="Receptek listája"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>


                <!-- RECIPES GRID -->

                <DataGrid Name="recipesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          MouseDoubleClick="recipesGrid_MouseDoubleClick"
                          RowBackground="#2b2b2b"
                          AlternatingRowBackground="#343434"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          Foreground="White"
                          FontSize="14">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FFC107"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>


                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>

                        <DataGridTextColumn Header="Cím"
                                            Binding="{Binding title}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Szerző"
                                            Binding="{Binding author_name}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Adag"
                                            Binding="{Binding servings}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Idő (perc)"
                                            Binding="{Binding prep_time_minutes}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Létrehozva"
                                            Binding="{Binding created_at}"
                                            Width="150"/>


                        <!-- IMAGE -->

                        <DataGridTemplateColumn Header="Kép" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImageSource}"
                                           Width="80"
                                           Height="50"
                                           Stretch="UniformToFill"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <!-- DELETE -->

                        <DataGridTemplateColumn Header="Művelet" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Törlés"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            FontWeight="Bold"
                                            Click="DeleteButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>


                <!-- CLOSE BUTTON -->

                <Button Content="Bezárás"
                        Width="120"
                        Height="40"
                        Margin="0,15,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#444"
                        Foreground="White"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>